<!DOCTYPE html>
<html>
<head>
  <title>Employee Directory | Employee Payroll</title>
  <style>
    :root {
      font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      color-scheme: light;
    }

    body {
      margin: 0;
      padding: 0;
      background: #f3f4f6;
      color: #111827;
    }

    .page-shell {
      width: 100%;
      max-width: 1180px;
      margin: 0 auto;
      padding: 28px 20px 40px;
    }

    .brand-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 28px;
      gap: 16px;
    }

    .brand-title {
      font-size: 26px;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .brand-description {
      color: #6b7280;
      margin: 6px 0 0;
      font-size: 15px;
      max-width: 560px;
    }

    .primary-button {
      background: #2563eb;
      color: white;
      padding: 14px 22px;
      border-radius: 12px;
      text-decoration: none;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      border: 1px solid transparent;
      transition: background 0.2s ease, transform 0.2s ease;
    }

    .primary-button:hover {
      background: #1d4ed8;
      transform: translateY(-1px);
    }

    .table-card {
      background: white;
      border-radius: 22px;
      border: 1px solid #e5e7eb;
      box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
      overflow: hidden;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 720px;
    }

    thead {
      background: #111827;
      color: white;
    }

    th, td {
      padding: 18px 20px;
      text-align: left;
      border-bottom: 1px solid #e5e7eb;
      vertical-align: middle;
      font-size: 14px;
    }

    th:first-child,
    td:first-child {
      padding-left: 24px;
    }

    tbody tr:hover {
      background: #f8fafc;
    }

    .photo-avatar {
      width: 58px;
      height: 58px;
      border-radius: 16px;
      object-fit: cover;
      box-shadow: 0 8px 16px rgba(15, 23, 42, 0.12);
      border: 1px solid #e5e7eb;
    }

    .user-name {
      font-weight: 700;
      color: #111827;
    }

    .user-role {
      color: #6b7280;
      font-size: 13px;
      margin-top: 4px;
    }

    .action-cell {
      display: flex;
      align-items: center;
      gap: 10px;
      justify-content: flex-start;
    }

    .action-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 42px;
      height: 42px;
      border-radius: 12px;
      text-decoration: none;
      border: 1px solid transparent;
      transition: background 0.2s ease, transform 0.2s ease;
      font-size: 16px;
    }

    .action-btn:hover {
      transform: translateY(-1px);
    }

    .edit {
      color: #2563eb;
      background: #eff6ff;
      border-color: #dbeafe;
    }

    .delete {
      color: #dc2626;
      background: #fef2f2;
      border-color: #fecaca;
    }

    .view {
      color: #0f766e;
      background: #ecfdf5;
      border-color: #a7f3d0;
    }

    .delete button {
      width: 42px;
      height: 42px;
      border: none;
      background: transparent;
      cursor: pointer;
      font-size: 16px;
    }

    .status-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #eef2ff;
      color: #4338ca;
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
      width: fit-content;
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <header class="brand-bar">
      <div>
        <div class="brand-title">Employee Directory</div>
        <p class="brand-description">Manage your employee records, review payroll details, and maintain a polished staff overview.</p>
      </div>
      <a href="/employees/add" class="primary-button">+ Add Employee</a>
    </header>

    <section class="table-card">
      <table>
        <thead>
          <tr>
            <th>Photo</th>
            <th>Name</th>
            <th>Department</th>
            <th>Salary</th>
            <th>Joining Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% employees.forEach(emp => { %>
            <tr>
              <td>
                <% if (emp.photo_url) { %>
                  <img src="<%= emp.photo_url %>" alt="Employee photo" class="photo-avatar" />
                <% } else { %>
                  <div class="photo-avatar" style="display:flex;align-items:center;justify-content:center;background:#f8fafc;color:#6b7280;font-size:12px;">No Photo</div>
                <% } %>
              </td>
              <td>
                <div class="user-name"><%= emp.name %></div>
                <div class="user-role"><%= emp.email %></div>
                <div class="user-role"><%= emp.gender || 'N/A' %></div>
              </td>
              <td><%= emp.dept %></td>
              <td>₹ <%= emp.basic_sal.toLocaleString('en-IN') %></td>
              <td><%= new Date(emp.date).toLocaleDateString('en-IN') %></td>
              <td class="action-cell">
                <a href="/employees/edit/<%= emp.id %>" class="action-btn edit" title="Edit">✏️</a>
                <form action="http://localhost:3000/employees/<%= emp.id %>?_method=DELETE" method="POST" class="delete">
                  <button type="submit" title="Delete">🗑️</button>
                </form>
                <a href="/employees/payroll/<%= emp.id %>" class="action-btn view" title="Payroll">📖</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </div>
</body>
</html>
