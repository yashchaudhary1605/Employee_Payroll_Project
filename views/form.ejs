<!DOCTYPE html>
<html>
<head>
  <title>Add Employee | Employee Payroll</title>
  <style>
    :root {
      color-scheme: light;
      font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    body {
      margin: 0;
      padding: 0;
      background: #edf2f7;
      color: #1f2937;
    }

    .page-shell {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 30px 20px 40px;
    }

    .brand-bar {
      width: 100%;
      max-width: 760px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 24px;
    }

    .brand-bar .brand {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: 0.04em;
    }

    .card {
      width: 100%;
      max-width: 640px;
      background: #ffffff;
      border-radius: 18px;
      box-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
      border: 1px solid #e5e7eb;
      padding: 32px;
    }

    .card h1 {
      margin: 0 0 12px;
      font-size: 26px;
      letter-spacing: 0.02em;
      color: #111827;
    }

    .card p.subtitle {
      margin: 0 0 24px;
      color: #6b7280;
      line-height: 1.6;
    }

    .field-row {
      border-bottom: 1px solid #e5e7eb;
      padding: 18px 0;
      display: grid;
      gap: 10px;
    }

    .field-row:last-of-type {
      border-bottom: none;
    }

    label {
      font-size: 14px;
      font-weight: 600;
      color: #111827;
    }

    input[type="text"],
    input[type="date"],
    input[type="number"],
    select {
      width: 100%;
      padding: 14px 16px;
      border: 1px solid #cbd5e1;
      border-radius: 12px;
      font-size: 15px;
      color: #111827;
      background: #fff;
    }

    .radio-group {
      display: flex;
      gap: 16px;
      align-items: center;
    }

    .radio-group label {
      font-weight: 500;
      color: #374151;
    }

    .radio-group input {
      margin-right: 8px;
    }

    .button-row {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin-top: 26px;
    }

    button,
    .secondary-button {
      min-height: 50px;
      border-radius: 12px;
      border: none;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
    }

    button {
      flex: 1 1 200px;
      background: #2563eb;
      color: white;
      transition: background 0.2s ease;
    }

    button:hover {
      background: #1d4ed8;
    }

    .secondary-button {
      flex: 1 1 200px;
      background: transparent;
      color: #2563eb;
      border: 1.5px solid #cbd5e1;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .secondary-button:hover {
      background: #f8fafc;
      border-color: #94a3b8;
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <header class="brand-bar">
      <div class="brand">Employee Payroll</div>
    </header>

    <section class="card">
      <h1>Add New Employee</h1>
      <p class="subtitle">Fill employee details below to add them to the payroll system with a polished profile. An email address will be generated automatically.</p>

      <form method="POST" action="/employees">
        <div class="field-row">
          <label for="name">Name</label>
          <input id="name" type="text" name="name" required>
        </div>

        <div class="field-row">
          <label>Gender</label>
          <div class="radio-group">
            <label><input type="radio" name="gender" value="Male" required> Male</label>
            <label><input type="radio" name="gender" value="Female"> Female</label>
          </div>
        </div>

        <div class="field-row">
          <label for="photoUrl">Photo URL</label>
          <input id="photoUrl" type="text" name="photoUrl" placeholder="https://example.com/photo.jpg">
        </div>

        <div class="field-row">
          <label for="department">Department</label>
          <input id="department" type="text" name="department" required>
        </div>

        <div class="field-row">
          <label for="email">Employee Email</label>
          <input id="email" type="email" name="email" placeholder="employee@gmail.com">
        </div>

        <div class="field-row">
          <label for="phone">Phone</label>
          <input id="phone" type="tel" name="phone" placeholder="e.g. +911234567890">
        </div>

        <div class="field-row">
          <label for="basicSalary">Basic Salary</label>
          <select id="basicSalary" name="basicSalary" required>
            <option value="">Select</option>
            <option value="10000">10000</option>
            <option value="20000">20000</option>
            <option value="30000">30000</option>
            <option value="40000">40000</option>
            <option value="50000">50000</option>
            <option value="60000">60000</option>
            <option value="70000">70000</option>
            <option value="80000">80000</option>
            <option value="90000">90000</option>
            <option value="100000">100000</option>
          </select>
        </div>

        <div class="field-row">
          <label for="joiningDate">Joining Date</label>
          <input id="joiningDate" type="date" name="joiningDate" required>
        </div>

        <div class="button-row">
          <button type="submit">Save Employee</button>
          <a href="/employees" class="secondary-button">Back to Employees</a>
        </div>
      </form>
    </section>
  </div>
</body>
</html>
